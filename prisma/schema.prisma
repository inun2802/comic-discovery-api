generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Publisher {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  characters Character[]
  series     Series[]
  teams      Team[]
  storyArcs  StoryArc[]
}

model Creator {
  id          String         @id
  name        String
  nationality String?
  birthYear   Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  issueLinks  IssueCreator[]

  @@index([name])
}

model IssueCreator {
  issueId    String
  creatorId  String
  role       String   // "writer", "penciler", "inker", "colorist", "letterer"

  issue      Issue    @relation(fields: [issueId], references: [id])
  creator    Creator  @relation(fields: [creatorId], references: [id])

  @@id([issueId, creatorId, role])
}

model Character {
  id          String            @id @default(cuid())
  name        String
  description String?
  publisherId String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  publisher   Publisher         @relation(fields: [publisherId], references: [id])
  jumpingOff  JumpingOffPoint[]
  issueLinks  IssueCharacter[]
  teamLinks   TeamMember[]

  @@unique([publisherId, name])
  @@index([name])
}

model Series {
  id          String     @id @default(cuid())
  title       String
  publisherId String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  publisher   Publisher  @relation(fields: [publisherId], references: [id])
  issues      Issue[]

  @@unique([publisherId, title])
  @@index([title])
}

model Issue {
  id                String           @id @default(cuid())
  seriesId          String
  issueNumber       String?
  title             String?
  releaseDate       DateTime?
  universe          String?          // "main", "ultimate", "absolute"
  isFirstAppearance Boolean          @default(false)
  isMajorCrossover  Boolean          @default(false)
  isKeyIssue        Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  series            Series           @relation(fields: [seriesId], references: [id])
  characterLinks    IssueCharacter[]
  teamLinks         IssueTeam[]
  storyArcLinks     StoryArcIssue[]

  @@index([releaseDate])
}

model IssueCharacter {
  issueId           String
  characterId       String
  role              String?          // "main", "supporting", "villain", "guest"
  isFirstAppearance Boolean          @default(false)

  issue             Issue            @relation(fields: [issueId], references: [id])
  character         Character        @relation(fields: [characterId], references: [id])

  @@id([issueId, characterId])
}

model JumpingOffPoint {
  id          String    @id @default(cuid())
  characterId String
  title       String
  blurb       String?
  tier        String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  character   Character @relation(fields: [characterId], references: [id])

  @@index([characterId])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  publisherId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  publisher   Publisher    @relation(fields: [publisherId], references: [id])
  members     TeamMember[]
  issueLinks  IssueTeam[]

  @@unique([publisherId, name])
  @@index([name])
}

model TeamMember {
  teamId      String
  characterId String

  team        Team      @relation(fields: [teamId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@id([teamId, characterId])
}

model IssueTeam {
  issueId    String
  teamId     String
  role       String?   // "main", "guest", "villain"

  issue      Issue     @relation(fields: [issueId], references: [id])
  team       Team      @relation(fields: [teamId], references: [id])

  @@id([issueId, teamId])
}

model StoryArc {
  id          String          @id @default(cuid())
  title       String
  description String?
  publisherId String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  publisher   Publisher       @relation(fields: [publisherId], references: [id])
  issues      StoryArcIssue[]

  @@unique([publisherId, title])
  @@index([title])
}

model StoryArcIssue {
  storyArcId  String
  issueId     String
  order       Int      @default(0)

  storyArc    StoryArc @relation(fields: [storyArcId], references: [id])
  issue       Issue    @relation(fields: [issueId], references: [id])

  @@id([storyArcId, issueId])
}